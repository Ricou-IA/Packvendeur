# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Environment files — contain secrets (Apify, etc.)
.env
.env.*
!.env.example

# Local Claude Code settings (may record secrets in permission allow-lists)
.claude/settings.local.json

# Claude Code session artifacts (locks, ad-hoc test outputs, agent transcripts)
# .claude/audits/, .claude/changelog/, .claude/tests/ are kept on purpose.
.claude/*.lock
.claude/*_test.json
.claude/tasks/
.claude/tool-results/

# Supabase CLI cache / temp
supabase/.temp/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
